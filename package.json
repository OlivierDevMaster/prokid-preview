{
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:fix:files": "eslint --fix",
    "typecheck": "npx tsc --noEmit --pretty",
    "fn:serve": "supabase functions serve",
    "db:restart": "supabase stop && supabase start",
    "db:reset:local": "supabase db reset --local && npm run db:generate:local",
    "db:accept-pending-missions": "dotenvx run -- tsx scripts/accept-pending-missions.ts",
    "db:reset:remote": "supabase db reset --linked && npm run db:accept-pending-missions",
    "db:generate:local": "supabase gen types typescript --local > types/database/schema.ts",
    "db:generate:remote": "supabase gen types typescript --linked > types/database/schema.ts",
    "db:delete-all": "tsx scripts/delete-all-data.ts",
    "db:delete-all-with-auth": "tsx scripts/delete-all-data-with-auth.ts",
    "fn:deploy": "supabase functions deploy",
    "test:send-report": "dotenvx run -- tsx scripts/test-send-report.ts",
    "stripe:listen:local": "stripe listen --forward-to http://127.0.0.1:54321/functions/v1/stripe-webhooks",
    "docker:restart": "docker stop $(docker ps -q) && npm run db:restart"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.0",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.511.0",
    "next": "16.0.10",
    "next-auth": "^4.24.13",
    "next-intl": "^4.5.5",
    "next-seo": "^7.0.1",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.5",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.68.0",
    "rrule": "^2.8.1",
    "sanitize-filename": "^1.6.3",
    "slugify": "^1.6.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.2",
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-config-next": "15.3.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-prettier": "^5.5.4",
    "postcss": "^8",
    "prettier": "^3.7.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.76.14",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "type-fest": "^5.3.0",
    "typescript": "^5"
  }
}
